# AMRShield - Environment Variables Template
# Copy this to .env and fill in your values

# ── Google Cloud ──
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ── Arize Phoenix ──
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_ENDPOINT=https://app.phoenix.arize.com

# ── Agent Builder ──
AGENT_BUILDER_LOCATION=global
AGENT_ID=your-agent-builder-agent-id

# ── Optional: Firestore ──
FIRESTORE_COLLECTION=amrshield_recommendations

# ── Dashboard Ports ──
CLINICIAN_PORT=8501
STEWARDSHIP_PORT=8502
SURVEILLANCE_PORT=8503
AUDIT_PORT=8504
